{
  "name": "brag",
  "private": true,
  "description": "Local-first, privacy-first record of achievements, goals, mentoring, enablement, and energy.",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "fmt": "oxfmt",
    "typecheck": "nuxt typecheck",
    "validate": "pnpm lint && pnpm typecheck",
    "db:migrations:generate": "drizzle-kit generate --config=drizzle.config.ts && pnpm db:migrations:embed",
    "db:migrations:embed": "node scripts/embed-migrations.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/public-sans": "^5.2.7",
    "@iconify-json/lucide": "^1.2.81",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/ui": "^4.3.0",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extensions": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/vue-3": "^3.26.0",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "markdown-it": "^14.2.0",
    "nuxt": "^4.4.4",
    "sqlocal": "^0.17.0",
    "tailwindcss": "^4.1.18",
    "tiptap-markdown": "^0.9.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/test-utils": "^3.21.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "^1.49.0",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.8"
  },
  "lint-staged": {
    "*.{js,mjs,ts,vue}": [
      "oxlint --fix",
      "eslint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@parcel/watcher",
      "unrs-resolver"
    ],
    "overrides": {
      "@tiptap/core": "3.26.0",
      "@tiptap/pm": "3.26.0"
    }
  }
}
